# ─────────────────────────────────────────
# Eklesia CMS Mobile — Expo Environment Variables
# Copy this file to .env and fill in the values
# Must be prefixed with EXPO_PUBLIC_ to be accessible in the app
# ─────────────────────────────────────────

# API Base URL — your deployed backend on Vercel or other
EXPO_PUBLIC_API_URL=https://your-backend.vercel.app/api/mobile
